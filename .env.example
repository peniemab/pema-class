# .env.local à la racine

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=votre_cle_anon_publique

# Serveur uniquement (inscription directeur, admin API)
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role

# URL publique de l'app (invitations staff, liens reset mot de passe).
# Doit être autorisée dans Supabase → Authentication → URL Configuration.
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
